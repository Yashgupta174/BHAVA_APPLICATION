<?xml version="1.0" encoding="utf-8"?>
<!--
    Place in:  res/anim/anim_artwork_rotate.xml

    Usage — start when music plays, stop when paused:
        val rotate = AnimationUtils.loadAnimation(context, R.anim.anim_artwork_rotate)
        binding.ivArtwork.startAnimation(rotate)   // play
        binding.ivArtwork.clearAnimation()          // pause
-->
<rotate
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromDegrees="0"
    android:toDegrees="360"
    android:pivotX="50%"
    android:pivotY="50%"
    android:duration="30000"
    android:repeatCount="infinite"
    android:interpolator="@android:anim/linear_interpolator" />
