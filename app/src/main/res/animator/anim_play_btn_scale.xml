<?xml version="1.0" encoding="utf-8"?>
<!--
    Place in:  res/anim/anim_play_btn_scale.xml

    Usage — call on every play/pause button tap:
        val scaleDown = AnimationUtils.loadAnimation(context, R.anim.anim_play_btn_scale)
        binding.btnPlayPause.startAnimation(scaleDown)
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/overshoot_interpolator">
    <scale
        android:fromXScale="1.0"
        android:toXScale="0.88"
        android:fromYScale="1.0"
        android:toYScale="0.88"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="100"
        android:repeatMode="reverse"
        android:repeatCount="1" />
</set>
