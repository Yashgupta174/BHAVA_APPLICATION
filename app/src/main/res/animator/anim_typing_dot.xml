<?xml version="1.0" encoding="utf-8"?>
<!--
    Place this file in:  res/animator/anim_typing_dot.xml

    Apply to each dot view with a different startOffset:
      Dot 1: startOffset = 0ms
      Dot 2: startOffset = 180ms
      Dot 3: startOffset = 360ms

    Kotlin usage:
        fun animateDot(view: View, delay: Long) {
            val set = AnimatorInflater.loadAnimator(context, R.animator.anim_typing_dot)
                as AnimatorSet
            set.setTarget(view)
            set.startDelay = delay
            set.start()
        }
        animateDot(binding.typingDot1, 0L)
        animateDot(binding.typingDot2, 180L)
        animateDot(binding.typingDot3, 360L)
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:ordering="together">

    <objectAnimator
        android:propertyName="alpha"
        android:valueFrom="0.3"
        android:valueTo="1.0"
        android:duration="450"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:interpolator/accelerate_decelerate" />

    <objectAnimator
        android:propertyName="translationY"
        android:valueFrom="0"
        android:valueTo="-5"
        android:duration="450"
        android:repeatMode="reverse"
        android:repeatCount="infinite"
        android:interpolator="@android:interpolator/accelerate_decelerate" />

</set>
