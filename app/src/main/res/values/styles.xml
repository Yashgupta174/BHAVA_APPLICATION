<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Challenge Card Style -->
    <style name="ChallengeCard">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">12dp</item>
        <item name="cardMaxElevation">16dp</item>
        <item name="rippleColor">@color/ripple_color</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Card Title Style -->
    <style name="CardTitle">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/crimson_pro</item>
        <item name="fontFamily">@font/crimson_pro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

    <!-- Card Description Style -->
    <style name="CardDescription">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:alpha">0.85</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

    <!-- Badge Style -->
    <style name="Badge">
        <item name="android:textSize">8sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingStart">7dp</item>
        <item name="android:paddingEnd">7dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:elevation">1dp</item>
    </style>

    <!-- Top Badge Style (Live, Featured, New) -->
    <style name="TopBadge">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:shadowColor">#80000000</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">4</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
    </style>

    <style name="FavTabTextAppearance" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Theme.DailyRoutine" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/accent_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_parchment</item>
        <item name="android:statusBarColor">@color/bg_parchment</item>
        <item name="android:navigationBarColor">@color/bg_parchment</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ChallengeDetail" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/accent_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_parchment</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_parchment</item>
    </style>

    <style name="Theme.BhavaChat" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/accent_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_parchment</item>
        <item name="android:statusBarColor">@color/bg_parchment</item>
        <item name="android:navigationBarColor">@color/bg_parchment</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SessionPlayer" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorPrimaryVariant">@color/accent_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_parchment</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/mini_player_bg</item>
    </style>

    <style name="Theme.DivyaStore" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/store_accent</item>
        <item name="colorPrimaryVariant">@color/store_accent2</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/store_bg</item>
        <item name="android:statusBarColor">@color/store_bg</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.MusicPlayer" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/player_accent</item>
        <item name="colorPrimaryVariant">@color/player_accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/player_bg</item>
        <item name="android:statusBarColor">@color/player_bg</item>
        <item name="android:navigationBarColor">@color/player_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Active indicator style (background for selected item) -->
    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/bottom_nav_indicator_color</item>
        <item name="android:height">32dp</item>
        <item name="android:width">64dp</item>
        <item name="shapeAppearance">@style/BottomNavIndicatorShape</item>
    </style>

    <!-- Shape for active indicator -->
    <style name="BottomNavIndicatorShape" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Activity Animations -->
    <style name="Animation.Bhava.Activity" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Global List Animation -->
    <style name="AnimatedRecyclerView">
        <item name="android:layoutAnimation">@anim/layout_fall_down</item>
    </style>
    <style name="CircleImage" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <!-- Professional Input Style -->
    <style name="ProfessionalInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/bhava_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/bhava_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="ProfessionalInputText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <!-- Global Typography System -->
    <style name="Bhava_TitleText">
        <item name="android:fontFamily">@font/crimson_pro</item>
        <item name="fontFamily">@font/crimson_pro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_espresso</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Bhava_SectionHeader">
        <item name="android:fontFamily">@font/crimson_pro</item>
        <item name="fontFamily">@font/crimson_pro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_espresso</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Bhava_BodyText">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Bhava_CaptionText">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>