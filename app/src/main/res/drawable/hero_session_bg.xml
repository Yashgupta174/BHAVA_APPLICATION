<?xml version="1.0" encoding="utf-8"?>
<!--
    Fallback background shown when no real hero image is set.
    Replace by loading a real image in the Activity:
        Glide.with(this).load(sessionImageUrl).into(binding.ivHero)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="180"
        android:startColor="@color/hero_dark_start"
        android:centerColor="@color/hero_dark_mid"
        android:endColor="@color/hero_dark_end" />
</shape>
