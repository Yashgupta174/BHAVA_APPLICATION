<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Inner Glow -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="4dp"
                android:color="@color/neon_orange_glow" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    
    <!-- Core Neon Line -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="@color/neon_orange_core" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
