<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Navigation Background with rounded top corners -->
<!-- Place in: res/drawable/bottom_nav_background.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10000000"/>
            <corners
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp"/>
        </shape>
    </item>
    
    <!-- Main background -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#FFFFFF"
                android:endColor="#F8F9FA"
                android:type="linear"/>
            <corners
                android:topLeftRadius="24dp"
                android:topRightRadius="24dp"/>
        </shape>
    </item>
    
    <!-- Top border accent -->
    <item android:top="2dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF6B35"/>
            <size android:height="3dp"/>
        </shape>
    </item>
</layer-list>
