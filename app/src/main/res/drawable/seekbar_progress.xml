<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background (unplayed) -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <solid android:color="@color/seekbar_unplayed"/>
            <size android:height="4dp"/>
        </shape>
    </item>
    <!-- Secondary progress (buffered) -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp"/>
                <solid android:color="#30E8732A"/>
                <size android:height="4dp"/>
            </shape>
        </clip>
    </item>
    <!-- Progress (played) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp"/>
                <gradient
                    android:type="linear"
                    android:angle="0"
                    android:startColor="@color/player_accent_dark"
                    android:centerColor="@color/player_accent"
                    android:endColor="@color/player_gold"/>
                <size android:height="4dp"/>
            </shape>
        </clip>
    </item>
</layer-list>
