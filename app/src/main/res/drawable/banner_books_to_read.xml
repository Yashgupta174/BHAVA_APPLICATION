<?xml version="1.0" encoding="utf-8"?>
<!--
    Banner for the "Books to Read" pinned card.
    Set as: binding.imgBanner.setImageResource(R.drawable.banner_books_to_read)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base sage green wash -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9EDE7" />
        </shape>
    </item>

    <!-- Large glow — left -->
    <item
        android:left="-20dp"
        android:top="10dp"
        android:right="220dp"
        android:bottom="-10dp">
        <shape android:shape="oval">
            <solid android:color="#66A8D5C8" />
        </shape>
    </item>

    <!-- Mid circle — centre -->
    <item
        android:left="110dp"
        android:top="-10dp"
        android:right="110dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#407BBFB0" />
        </shape>
    </item>

    <!-- Accent — right -->
    <item
        android:left="240dp"
        android:top="8dp"
        android:right="-10dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#4DA8D5C8" />
        </shape>
    </item>

</layer-list>
