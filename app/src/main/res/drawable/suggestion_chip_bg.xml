<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the right-aligned suggestion chips.
    Asymmetric radius: top-right corner is sharp to simulate
    a chat bubble pointing to the top-right (sent message style).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners
        android:topLeftRadius="20dp"
        android:topRightRadius="4dp"
        android:bottomLeftRadius="20dp"
        android:bottomRightRadius="20dp" />
    <solid android:color="@color/bg_warm_cream" />
    <stroke
        android:width="1dp"
        android:color="@color/divider_warm" />
</shape>
