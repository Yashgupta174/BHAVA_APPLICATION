<?xml version="1.0" encoding="utf-8"?>
<!--
    Banner for the "Morning Rituals" pinned card.
    Set as: binding.imgBanner.setImageResource(R.drawable.banner_morning_rituals)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base warm gold wash -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5E8C8" />
        </shape>
    </item>

    <!-- Large glow circle — right -->
    <item
        android:left="180dp"
        android:top="0dp"
        android:right="-20dp"
        android:bottom="-20dp">
        <shape android:shape="oval">
            <solid android:color="#59E8C97A" />
        </shape>
    </item>

    <!-- Smaller accent — top right -->
    <item
        android:left="240dp"
        android:top="-10dp"
        android:right="0dp"
        android:bottom="30dp">
        <shape android:shape="oval">
            <solid android:color="#33D4A855" />
        </shape>
    </item>

    <!-- Bottom-left soft circle -->
    <item
        android:left="-10dp"
        android:top="40dp"
        android:right="260dp"
        android:bottom="-10dp">
        <shape android:shape="oval">
            <solid android:color="#22EDD48A" />
        </shape>
    </item>

</layer-list>
