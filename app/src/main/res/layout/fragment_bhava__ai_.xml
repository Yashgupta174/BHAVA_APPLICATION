<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ════════════════════════════════════════ -->
    <!--              TOP APP BAR                 -->
    <!-- ════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_parchment"
        android:paddingHorizontal="8dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back arrow -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@android:color/transparent"
            android:tint="@color/text_espresso"
            android:padding="8dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Back" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bhava_ai_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_espresso"
            android:layout_centerInParent="true" />

        <!-- More options -->
        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:background="@android:color/transparent"
            android:tint="@color/text_espresso"
            android:padding="8dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="More options" />

    </RelativeLayout>

    <!-- Thin decorative divider under top bar -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_warm"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ════════════════════════════════════════ -->
    <!--           CHAT SCROLL AREA               -->
    <!-- ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbarThumbVertical="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintBottom_toTopOf="@id/disclaimerText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- ── Warning / Logo Icon ── -->
            <ImageView
                android:id="@+id/ivBhavaIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_bhava_logo"
                android:tint="@color/accent_gold"
                android:layout_marginBottom="16dp"
                android:contentDescription="Bhava AI" />

            <!-- ── Intro Message Bubble (System) ── -->
            <TextView
                android:id="@+id/tvIntroMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bhava_intro"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="serif"
                android:textColor="@color/text_espresso"
                android:layout_marginBottom="28dp" />

            <!-- ── Suggestion Chip 1 (right-aligned) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/chipQuestion1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bhava_q1"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_espresso"
                    android:background="@drawable/suggestion_chip_bg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp"
                    android:maxWidth="290dp" />
            </LinearLayout>

            <!-- ── Suggestion Chip 2 (right-aligned, slightly less) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/chipQuestion2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bhava_q2"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_espresso"
                    android:background="@drawable/suggestion_chip_bg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp"
                    android:maxWidth="260dp" />
            </LinearLayout>

            <!-- ── Suggestion Chip 3 (right-aligned, most indented) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/chipQuestion3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bhava_q3"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_espresso"
                    android:background="@drawable/suggestion_chip_bg"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp"
                    android:maxWidth="240dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════ -->
    <!--          DISCLAIMER TEXT                 -->
    <!-- ════════════════════════════════════════ -->
    <TextView
        android:id="@+id/disclaimerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bhava_disclaimer"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:textColor="@color/text_caramel"
        android:lineSpacingMultiplier="1.4"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ════════════════════════════════════════ -->
    <!--          BOTTOM INPUT BAR                -->
    <!-- ════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/inputCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_cream"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="4dp"
            android:minHeight="56dp">

            <EditText
                android:id="@+id/etInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/bhava_input_hint"
                android:textColorHint="@color/text_caramel"
            android:textColor="@color/text_espresso"
            android:textSize="15sp"
            android:fontFamily="sans-serif"
            android:background="@android:color/transparent"
            android:paddingVertical="14dp"
            android:paddingEnd="44dp"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnSend" />

            <!-- Send button -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/send_btn_bg"
                android:padding="8dp"
                android:tint="@color/card_cream"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Send" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
