<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Artwork thumbnail -->
    <FrameLayout
        android:id="@+id/queueThumbFrame"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@drawable/bg_queue_thumb"
        android:layout_marginEnd="14dp">

        <ImageView
            android:id="@+id/ivQueueThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/player_artwork_default"
            android:contentDescription="Track thumbnail" />

        <!-- Playing indicator overlay (visible only for currently playing) -->
        <FrameLayout
            android:id="@+id/playingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_queue_playing_overlay"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_equalizer"
                android:tint="@color/white"
                android:contentDescription="Playing" />

        </FrameLayout>

    </FrameLayout>

    <!-- Track info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvQueueTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track Title"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/player_text"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/tvQueueSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist · Album"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:textColor="@color/player_muted"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Duration -->
    <TextView
        android:id="@+id/tvQueueDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5:42"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:textColor="@color/player_muted"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp" />

    <!-- Active playing bar (visible only for current track) -->
    <View
        android:id="@+id/activeBar"
        android:layout_width="3dp"
        android:layout_height="22dp"
        android:background="@drawable/bg_active_bar"
        android:visibility="gone" />

</LinearLayout>
