<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ════════════════════════════════════════ -->
    <!--          COLLAPSING HERO HEADER          -->
    <!-- ════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bg_parchment"
            app:titleEnabled="false">

            <!-- Hero background image / gradient -->
            <View
                android:id="@+id/heroBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient_bg"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5" />

            <!-- "Join Challenge" pill button centered in hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_collapseMode="parallax">

                <Button
                    android:id="@+id/btnJoinChallenge"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:text="@string/btn_join_challenge"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/text_espresso"
                    android:background="@drawable/join_btn_bg"
                    android:paddingHorizontal="40dp"
                    app:cornerRadius="50dp" />
            </LinearLayout>

            <!-- Back button pinned top-start -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/circle_btn_bg"
                android:padding="10dp"
                android:tint="@color/text_espresso"
                android:layout_gravity="top|start"
                android:layout_margin="14dp"
                android:contentDescription="@string/cd_back"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ════════════════════════════════════════ -->
    <!--          SCROLLABLE BODY                 -->
    <!-- ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarThumbVertical="@android:color/transparent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── Info Card (title, featuring, description, badges) ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="18dp">

                    <!-- ── DYNAMIC TITLE — id = textTitle ── -->
                    <TextView
                        android:id="@+id/textTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/challenge_title_placeholder"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textColor="@color/text_espresso"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="14dp" />

                    <!-- ── "Featuring" label ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/featuring_label"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_brown"
                        android:layout_marginBottom="10dp" />

                    <!-- ── Featuring row (avatars + names) ── -->
                    <LinearLayout
                        android:id="@+id/featuringRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <!-- Host 1 avatar -->
                        <ImageView
                            android:id="@+id/ivHost1"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/placeholder_avatar"
                            android:background="@drawable/avatar_bg"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Host 1" />

                        <!-- Host 1 name -->
                        <TextView
                            android:id="@+id/tvHost1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/host1_name_placeholder"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginEnd="18dp" />

                        <!-- Host 2 avatar -->
                        <ImageView
                            android:id="@+id/ivHost2"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/placeholder_avatar"
                            android:background="@drawable/avatar_bg"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Host 2" />

                        <!-- Host 2 name -->
                        <TextView
                            android:id="@+id/tvHost2Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/host2_name_placeholder"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso" />

                    </LinearLayout>

                    <!-- ── Description (truncated with MORE) ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/challenge_desc_placeholder"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_brown"
                            android:lineSpacingMultiplier="1.5"
                            android:maxLines="3"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_more"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_caramel"
                            android:layout_gravity="bottom"
                            android:paddingStart="4dp" />
                    </LinearLayout>

                    <!-- ── Badges row (joined count + starts in) ── -->
                    <LinearLayout
                        android:id="@+id/badgesRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvJoinedBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_joined_placeholder"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/card_cream"
                            android:background="@drawable/badge_filled_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvStartsBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_starts_placeholder"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/accent_gold"
                            android:background="@drawable/badge_outline_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Divider between info card and session list ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginTop="4dp" />

            <!-- ════════════════════════════════ -->
            <!--        SESSION LIST              -->
            <!--   (repeated item rows)           -->
            <!-- ════════════════════════════════ -->

            <!-- Session Item 1 -->
            <include layout="@layout/item_session"
                android:id="@+id/session1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginHorizontal="20dp" />

            <!-- Session Item 2 -->
            <include layout="@layout/item_session"
                android:id="@+id/session2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginHorizontal="20dp" />

            <!-- Session Item 3 -->
            <include layout="@layout/item_session"
                android:id="@+id/session3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginHorizontal="20dp" />

            <!-- Session Item 4 -->
            <include layout="@layout/item_session"
                android:id="@+id/session4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!--
                For dynamic lists, replace <include> blocks with a
                RecyclerView and an adapter instead.
            -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
