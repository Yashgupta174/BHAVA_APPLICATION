<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient">

    <!-- ══ PREMIUM FIXED HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bhava_background"
        android:elevation="6dp">

        <!-- Top action row: back + title + filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <!-- Back arrow -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_icon_btn"
                android:tint="@color/text_espresso"
                android:padding="9dp"
                android:contentDescription="Back"
                android:stateListAnimator="@null"/>

            <!-- Title block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY LIBRARY"
                    android:fontFamily="@font/inter"
                    android:textSize="9sp"
                    android:textColor="@color/text_caramel"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="1dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Favourites"
                    android:fontFamily="@font/crimson_pro"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_espresso"
                    android:letterSpacing="-0.01"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- Count badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtCollectionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— "
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:textColor="@color/text_caramel"/>

                <View
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/shape_dot"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/txtSessionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:textColor="@color/text_caramel"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/bhava_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:tabGravity="start"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@color/text_espresso"
            app:tabTextColor="@color/text_caramel"
            app:tabTextAppearance="@style/FavTabTextAppearance"
            app:tabIndicatorColor="@color/bhava_primary"
            app:tabIndicatorHeight="2dp"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorGravity="bottom"
            app:tabRippleColor="@color/ripple_brown"
            app:tabPaddingStart="6dp"
            app:tabPaddingEnd="6dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Collections"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions"/>

        </com.google.android.material.tabs.TabLayout>

        <!-- Hair divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_warm"
            android:alpha="0.6"/>

    </LinearLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshFav"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="148dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFavorites"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="80dp"
                android:scrollbars="none"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/pbFavLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/bhava_primary"
                android:visibility="gone"/>

            <!-- Premium Empty State -->
            <LinearLayout
                android:id="@+id/tvFavEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_favorite_minimal"
                    android:tint="@color/divider_warm"
                    android:alpha="0.6"
                    android:contentDescription="No favourites"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No favourites yet"
                    android:fontFamily="@font/crimson_pro"
                    android:textSize="22sp"
                    android:textColor="@color/text_brown"
                    android:layout_marginTop="16dp"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sessions and collections you save\nwill appear here."
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:textColor="@color/text_caramel"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>
            </LinearLayout>

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>