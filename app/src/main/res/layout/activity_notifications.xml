<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient">

    <!-- ══ PREMIUM FIXED HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#00000000"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Back arrow -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_icon_btn"
                android:tint="@color/text_espresso"
                android:padding="9dp"
                android:contentDescription="Back"
                android:stateListAnimator="@null"/>

            <!-- Title block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STAY INFORMED"
                    android:fontFamily="@font/inter"
                    android:textSize="9sp"
                    android:textColor="@color/text_caramel"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="1dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:fontFamily="@font/crimson_pro"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_espresso"
                    android:letterSpacing="-0.01"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnClearAll"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_delete_minimal"
                app:tint="@color/text_espresso"
                android:padding="8dp"
                android:contentDescription="Clear All"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_gravity="center"
        android:padding="32dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_bell_minimal"
            android:tint="@color/divider_warm"
            android:alpha="0.8"
            android:contentDescription="No notifications"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No notifications yet"
            android:textColor="@color/text_brown"
            android:textSize="22sp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/crimson_pro"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay tuned for spiritual updates\nand new challenges."
            android:textColor="@color/text_caramel"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"/>
    </LinearLayout>

    <!-- RecyclerView for Notifications -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="80dp"
        android:paddingBottom="24dp"
        android:scrollbars="none"
        tools:listitem="@layout/item_notification"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
