<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="14dp"
    android:paddingEnd="64dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <!-- Bhava AI Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#C89858"
        app:cardBackgroundColor="#6b4423"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="10dp">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_ask_bhava_ai"
            android:tint="#FFFFFF"
            android:contentDescription="Bhava AI"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI Message Bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="260dp">

        <TextView
            android:id="@+id/tvChatContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_ai_bubble"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:text="Spiritual guidance response..."
            android:textColor="@color/text_espresso"
            android:fontFamily="@font/inter"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"/>
    </LinearLayout>

</LinearLayout>
