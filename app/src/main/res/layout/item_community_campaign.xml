<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="335dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/challenge_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/challeneg_40days_geeta"
                android:contentDescription="Campaign Image" />

            <!-- Optional Badge overlay like in original item_challenge if needed -->
            <TextView
                android:id="@+id/badge_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:text="● 12,397 Listening"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_live"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_content_bg"
            android:padding="20dp">

            <TextView
                android:id="@+id/challenge_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Global Peace Prayer"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/challenge_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unite for World Harmony"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/joined_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 12,397"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/badge_outlined"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/duration_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day 4 of 7"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/badge_outlined"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
