<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient">

    <!-- ══ PREMIUM FIXED HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#00000000"
        android:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="36dp"
            android:paddingBottom="14dp">

            <!-- Back arrow -->
            <ImageButton
                android:id="@+id/tvBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_icon_btn"
                android:tint="@color/text_espresso"
                android:padding="9dp"
                android:contentDescription="Back"
                android:stateListAnimator="@null"/>
            
            <!-- Kept tvBack ID because Java code uses it for the click listener -->
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="42dp"
            android:gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Us"
                android:fontFamily="@font/crimson_pro"
                android:textSize="32sp"
                android:textColor="@color/text_espresso"
                android:textStyle="bold"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We'd love to hear from you. Send us your message and we'll respond with devotion."
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textColor="@color/text_caramel"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"/>

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name *"
                android:fontFamily="@font/inter"
                android:textSize="12sp"
                android:textColor="@color/text_caramel"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>
                
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Your Name"
                android:textColorHint="#C8A882"
                android:textColor="@color/text_espresso"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:inputType="textPersonName"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Mobile No. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile No. *"
                android:fontFamily="@font/inter"
                android:textSize="12sp"
                android:textColor="@color/text_caramel"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>
                
            <EditText
                android:id="@+id/etMobile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="10-digit mobile number"
                android:textColorHint="#C8A882"
                android:textColor="@color/text_espresso"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:inputType="phone"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Email (Optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email (Optional)"
                android:fontFamily="@font/inter"
                android:textSize="12sp"
                android:textColor="@color/text_caramel"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>
                
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:hint="Email address"
                android:textColorHint="#C8A882"
                android:textColor="@color/text_espresso"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Message *"
                android:fontFamily="@font/inter"
                android:textSize="12sp"
                android:textColor="@color/text_caramel"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp"/>
                
            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:hint="Describe your message..."
                android:textColorHint="#C8A882"
                android:textColor="@color/text_espresso"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:background="@drawable/bg_input_field"
                android:padding="16dp"
                android:layout_marginBottom="24dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:visibility="gone"
                android:layout_gravity="center"
                android:indeterminateTint="@color/bhava_primary"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Submit"
                android:textColor="@color/white"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="27dp"
                app:backgroundTint="@color/bhava_primary"
                app:elevation="2dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
