<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_parchment"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:tint="@color/text_espresso"
            android:padding="10dp"
            android:contentDescription="Go back"
            android:stateListAnimator="@null" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/accent_color"
            android:background="@drawable/ripple_text_btn"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Routine"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_espresso"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wednesday, 18 March 2026"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_caramel"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Progress Strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_progress_strip"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's progress"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_caramel"
                    android:layout_marginEnd="12dp" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_track"
                    android:layout_marginEnd="12dp">

                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_progress_fill"
                        android:layout_gravity="start" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tvProgressCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 / 5"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/accent_color" />

            </LinearLayout>

            <!-- SECTION: Morning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_section_dot"
                    android:backgroundTint="@color/accent_color"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Morning"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/text_espresso"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:00 – 9:00 AM"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_caramel_light"
                    android:background="@drawable/bg_section_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </LinearLayout>

            <!-- Card: Daily Gospel -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDailyGospel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardMaxElevation="10dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:id="@+id/accentBarGospel"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@drawable/bg_accent_bar"
                        android:visibility="visible" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/bg_thumb"
                            android:backgroundTint="@color/thumb_gospel">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textSize="28sp"
                                android:text="📖" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Daily Gospel"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso"
                                android:layout_marginBottom="3dp"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="John 15:5 — I am the vine; you are the branches…"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/text_caramel"
                                android:lineSpacingMultiplier="1.4"
                                android:layout_marginBottom="6dp"
                                android:maxLines="2"
                                android:ellipsize="end" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Scripture"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif"
                                    android:textColor="@color/chip_text_orange"
                                    android:background="@drawable/bg_chip_orange"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:layout_marginEnd="5dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="15 min"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif"
                                    android:textColor="@color/chip_text_blue"
                                    android:background="@drawable/bg_chip_blue"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:layout_gravity="center_vertical">

                            <ImageButton
                                android:id="@+id/btnMoreGospel"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/ic_more_vert"
                                android:background="@drawable/bg_icon_btn_small"
                                android:padding="6dp"
                                android:contentDescription="More options"
                                android:stateListAnimator="@null"
                                android:layout_marginBottom="8dp" />

                            <ImageButton
                                android:id="@+id/btnCheckGospel"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_check"
                                android:background="@drawable/bg_check_circle_filled"
                                android:padding="5dp"
                                android:contentDescription="Mark as done"
                                android:stateListAnimator="@null" />

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Morning Pooja -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMorningPooja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardMaxElevation="10dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_thumb"
                        android:backgroundTint="@color/thumb_pooja">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="28sp"
                            android:text="🪔" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Morning Pooja"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginBottom="3dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lighting the diya, offering flowers and chanting mantras"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="6dp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Devotion"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_orange"
                                android:background="@drawable/bg_chip_orange"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20 min"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_blue"
                                android:background="@drawable/bg_chip_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnMorePooja"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_more_vert"
                            android:background="@drawable/bg_icon_btn_small"
                            android:padding="6dp"
                            android:contentDescription="More options"
                            android:stateListAnimator="@null"
                            android:layout_marginBottom="8dp" />

                        <ImageButton
                            android:id="@+id/btnCheckPooja"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_check"
                            android:background="@drawable/bg_check_circle_filled"
                            android:padding="5dp"
                            android:contentDescription="Mark as done"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: Midday -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_section_dot"
                    android:backgroundTint="#1D9E75"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Midday"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/text_espresso"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:00 – 2:00 PM"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_caramel_light"
                    android:background="@drawable/bg_section_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </LinearLayout>

            <!-- Card: Guided Meditation -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMeditation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardMaxElevation="10dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_thumb"
                        android:backgroundTint="@color/thumb_meditation">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="28sp"
                            android:text="🧘" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guided Meditation"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginBottom="3dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Breath awareness and mindfulness with Bhava AI"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="6dp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wellness"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_green"
                                android:background="@drawable/bg_chip_green"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10 min"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_blue"
                                android:background="@drawable/bg_chip_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnMoreMeditation"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_more_vert"
                            android:background="@drawable/bg_icon_btn_small"
                            android:padding="6dp"
                            android:contentDescription="More options"
                            android:stateListAnimator="@null"
                            android:layout_marginBottom="8dp" />

                        <ImageButton
                            android:id="@+id/btnCheckMeditation"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_check"
                            android:background="@drawable/bg_check_circle_empty"
                            android:padding="5dp"
                            android:contentDescription="Mark as done"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Gratitude Journal -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGratitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardMaxElevation="10dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_thumb"
                        android:backgroundTint="@color/thumb_journal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="28sp"
                            android:text="📓" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gratitude Journal"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginBottom="3dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Write 3 things you are grateful for today"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="6dp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reflection"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_blue"
                                android:background="@drawable/bg_chip_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 min"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_blue"
                                android:background="@drawable/bg_chip_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnMoreGratitude"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_more_vert"
                            android:background="@drawable/bg_icon_btn_small"
                            android:padding="6dp"
                            android:contentDescription="More options"
                            android:stateListAnimator="@null"
                            android:layout_marginBottom="8dp" />

                        <ImageButton
                            android:id="@+id/btnCheckGratitude"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_check"
                            android:background="@drawable/bg_check_circle_empty"
                            android:padding="5dp"
                            android:contentDescription="Mark as done"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Evening Prayer -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEveningPrayer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardMaxElevation="10dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <FrameLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_thumb"
                        android:backgroundTint="@color/thumb_evening">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="28sp"
                            android:text="🌙" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Evening Prayer"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginBottom="3dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sandhya vandanam and closing gratitude chants"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="6dp"
                            android:maxLines="2"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Devotion"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_orange"
                                android:background="@drawable/bg_chip_orange"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12 min"
                                android:textSize="10sp"
                                android:textColor="@color/chip_text_blue"
                                android:background="@drawable/bg_chip_blue"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnMoreEvening"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_more_vert"
                            android:background="@drawable/bg_icon_btn_small"
                            android:padding="6dp"
                            android:contentDescription="More options"
                            android:stateListAnimator="@null"
                            android:layout_marginBottom="8dp" />

                        <ImageButton
                            android:id="@+id/btnCheckEvening"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_check"
                            android:background="@drawable/bg_check_circle_empty"
                            android:padding="5dp"
                            android:contentDescription="Mark as done"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Add New Routine Button -->
            <Button
                android:id="@+id/btnAddRoutine"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:text="+ Add New Routine"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/white"
                android:background="@drawable/bg_add_btn"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
