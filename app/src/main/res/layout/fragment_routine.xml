<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ════════════════════════════════════════ -->
    <!--              TOP NAV ROW                 -->
    <!-- ════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button — circular cream background -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/circle_btn_bg"
            android:padding="10dp"
            android:tint="@color/text_espresso"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@string/cd_back" />

        <!-- Edit text button -->
        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/routine_edit"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_espresso"
            android:background="@drawable/ripple_text_btn"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>

    <!-- ════════════════════════════════════════ -->
    <!--         SCROLLABLE CONTENT               -->
    <!-- ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbarThumbVertical="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── Page Title ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/routine_title"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_espresso"
                android:paddingHorizontal="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- ── Date Subtitle ── -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/routine_date"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_brown"
                android:paddingHorizontal="20dp"
                android:paddingBottom="16dp" />

            <!-- ── Horizontal divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Time Group Label ── -->
            <TextView
                android:id="@+id/tvTimeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/routine_time"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_espresso"
                android:paddingHorizontal="20dp"
                android:paddingBottom="14dp" />

            <!-- ════════════════════════════════ -->
            <!--      ROUTINE ITEM CARD           -->
            <!-- ════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDailyGospel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="@color/card_cream">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:minHeight="80dp">

                    <!-- Thumbnail image -->
                    <ImageView
                        android:id="@+id/ivThumbnail"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/gospel_card_bg"
                        android:background="@drawable/thumbnail_bg"
                        android:scaleType="centerCrop"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="Daily Gospel thumbnail" />

                    <!-- Three-dot overflow menu -->
                    <ImageButton
                        android:id="@+id/btnItemMore"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_more_horiz"
                        android:background="@android:color/transparent"
                        android:tint="@color/text_brown"
                        android:padding="6dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="More options" />

                    <!-- Title + Subtitle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/ivThumbnail"
                        android:layout_toStartOf="@id/btnItemMore"
                        android:layout_centerVertical="true"
                        android:paddingHorizontal="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gospel_item_title"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gospel_item_subtitle"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_brown"
                            android:lineSpacingMultiplier="1.3" />

                    </LinearLayout>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!--
                Add more CardViews here for additional routine items.
                Each follows the same structure as cardDailyGospel above.
            -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
