<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ─── Main Scrollable Content ─── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbarThumbVertical="@android:color/transparent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="90dp">

            <!-- ════════════════════════════════════ -->
            <!--            HEADER ROW                -->
            <!-- ════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivProfileAvatar"
                        android:layout_width="68dp"
                        android:layout_height="68dp"
                        android:src="@drawable/placeholder_avatar"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_btn_bg"
                        android:contentDescription="Profile avatar"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:id="@+id/llProfileHeader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:padding="6dp">

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/crimson_pro"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvProfileSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile &amp; settings"
                            android:textSize="12sp"
                            android:textColor="@color/text_espresso"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvProfileStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to view and edit your profile"
                            android:textSize="11sp"
                            android:textColor="@color/black"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnFriends"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_group"
                            android:background="@drawable/circle_btn_bg"
                            android:padding="10dp"
                                app:tint="@color/text_espresso"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Friends" />

                        <ImageButton
                            android:id="@+id/btnSettings"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_settings"
                            android:background="@drawable/circle_btn_bg"
                            android:padding="10dp"
                                app:tint="@color/text_espresso"
                            android:contentDescription="Settings" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════ -->
            <!--            STREAK SECTION            -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Streak ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="22sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textColor="@color/black"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pray today and start building a habit!"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/black" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════ -->
            <!--      JOINED CHALLENGES SECTION       -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Challenges ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJoinedChallenges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="@color/card_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvJoinedChallengesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 challenges joined"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_espresso" />

                    <TextView
                        android:id="@+id/tvJoinedChallengesHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find a challenge on the home screen to begin your journey."
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════ -->
            <!--          ROUTINE SECTION             -->
            <!-- ════════════════════════════════════ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Routine ›"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/crimson_pro"
                    android:textColor="@color/black"
                    android:layout_centerVertical="true" />

                <TextView
                    android:id="@+id/btnEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit"
                    android:textSize="13sp"
                    android:textColor="@color/card_cream"
                    android:background="@drawable/edit_btn_bg"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="7dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>

            <!-- Single "My Routine" Tile -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMyRoutine"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="9dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Decorative background -->
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/gospel_card_bg" />

                    <!-- Bottom gradient fade -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/card_bottom_fade" />

                    <!-- Text content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Routine"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/crimson_pro"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvRoutineCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spiritual practices tailored for you"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="#EDD9C0" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════ -->
            <!--       RECENTLY PRAYED SECTION        -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:id="@+id/tvRecentlyPrayedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recently Prayed ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="22dp"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Morning Offering Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMorningOffering"
                        android:layout_width="155dp"
                        android:layout_height="195dp"
                        android:layout_marginEnd="14dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/morning_card_bg" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/card_bottom_fade" />

                            <!-- Checkmark -->
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/card_cream"
                                android:layout_gravity="top|end"
                                android:layout_margin="10dp"
                                android:contentDescription="Completed" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_gravity="bottom"
                                android:paddingHorizontal="12dp"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Morning Offering"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:fontFamily="serif"
                                    android:textColor="#FFFFFF" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Begin your day"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif"
                                    android:textColor="#EDD9C0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1 session"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif"
                                    android:textColor="@color/text_caramel" />
                            </LinearLayout>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ════════════════════════════════════ -->
            <!--          FAVORITES SECTION           -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:id="@+id/tvFavoritesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorites ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardFavorites"
                android:layout_width="155dp"
                android:layout_height="130dp"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_cream">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_star_border"
                        app:tint="@color/text_caramel"
                        android:layout_gravity="center"
                        android:contentDescription="No favorites yet" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════ -->
            <!--         DOWNLOADS SECTION            -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:id="@+id/tvDownloadsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Downloads ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardDownloads"
                android:layout_width="155dp"
                android:layout_height="130dp"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_cream"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_download"
                        app:tint="@color/text_caramel"
                        android:layout_gravity="center"
                        android:contentDescription="No downloads yet" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════ -->
            <!--        INTENTIONS SECTION            -->
            <!-- ════════════════════════════════════ -->
            <RelativeLayout
                android:id="@+id/rlIntentionsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intentions ›"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/crimson_pro"
                    android:textColor="@color/black"
                    android:layout_centerVertical="true" />

                <ImageButton
                    android:id="@+id/btnAddIntention"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_add_circle"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_espresso"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Add intention" />
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAddIntentions"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="22dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_cream"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="＋  Add Intentions"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_caramel" />
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════ -->
            <!--       SERVICES & SUPPORT SECTION     -->
            <!-- ════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Services &amp; Support ›"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp" />

            <!-- Row 1: Orders & Cart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="14dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOrders"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_cream"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_orders"
                            app:tint="@color/text_espresso"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Orders"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCart"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_cream"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_cart"
                            app:tint="@color/text_espresso"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Cart"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Row 2: Contact & Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="32dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardContact"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_cream"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_send"
                            app:tint="@color/text_espresso"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Us"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogout"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/card_cream"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/text_espresso"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logout"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>


    </androidx.core.widget.NestedScrollView>

