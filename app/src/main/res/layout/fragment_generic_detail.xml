<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- Mandala Background Overlay -->
    <ImageView
        android:layout_width="450dp"
        android:layout_height="450dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-120dp"
        android:src="@drawable/ic_mandala_overlay"
        android:alpha="0.08"
        app:tint="@color/premium_maroon"
        android:contentDescription="Background texture" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bg_parchment"
            app:titleEnabled="false">

            <ImageView
                android:id="@+id/ivHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hero_session_bg"
                android:scaleType="centerCrop"
                android:contentDescription="Session artwork"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4" />

            <!-- Soft bottom gradient more aligned with premium ivory theme -->
            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay_bottom"
                android:alpha="0.6"
                app:layout_collapseMode="parallax" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="bottom|center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="74dp"
                app:layout_collapseMode="parallax">

                <TextView
                    android:id="@+id/tvDetailMainTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The Luminous Mysteries"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/premium_text_espresso"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSessionSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guided Contemplative Prayer"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:letterSpacing="0.04"
                    android:background="@drawable/premium_button_maroon"
                    android:alpha="0.85"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

            <!-- GUIDE & MEDIA BOXES (REF 2 STYLE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="-1dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/premium_ivory"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/selectorGuide"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guide"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/premium_text_tan"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvGuideName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="YASH GUPTA"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/premium_text_espresso"
                                android:layout_marginEnd="6dp" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_chevron_down"
                                app:tint="@color/premium_text_espresso"
                                android:contentDescription="Expand guide" />

                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider_warm"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/selectorMedia"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Media Options"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/premium_text_tan"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvMediaDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="23min"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/premium_text_espresso"
                                android:layout_marginEnd="6dp" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_chevron_down"
                                app:tint="@color/premium_text_espresso"
                                android:contentDescription="Expand media" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/premium_button_maroon"
                android:alpha="0.6"
                android:padding="10dp"
                app:tint="@color/white"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:contentDescription="Go back"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- MAIN ACTION BUTTONS (CAPSULE STYLE) -->
            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:text="Begin Session"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/white"
                android:background="@drawable/premium_button_maroon"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:elevation="6dp" />

            <Button
                android:id="@+id/btnJoinChallenge"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="12dp"
                android:text="Join this Challenge"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/premium_maroon"
                android:background="@drawable/premium_button_ivory_outline"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnPrayIntention"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="24dp"
                android:text="Pray for an Intention"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/premium_maroon"
                android:background="@drawable/premium_button_ivory_outline"
                app:backgroundTint="@null"
                android:stateListAnimator="@null" />

            <!-- RESTORING FEATURING LABEL TO FIX COMPILATION -->
            <TextView
                android:id="@+id/tvFeaturingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEATURING"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/premium_text_tan"
                android:letterSpacing="0.1"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/hostsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESSIONS"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/premium_text_tan"
                android:letterSpacing="0.1"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_session" />

            <!-- RESTORING PROGRESS BAR TO FIX COMPILATION -->
            <ProgressBar
                android:id="@+id/pbSessionsLoading"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                android:indeterminateTint="@color/premium_maroon" />

            <!-- SUMMARY & DESCRIPTION -->
            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quick summary..."
                android:textSize="15sp"
                android:fontFamily="serif"
                android:textColor="@color/premium_text_espresso"
                android:lineSpacingMultiplier="1.4"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading detailed description..."
                android:textSize="14.5sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/premium_text_tan"
                android:lineSpacingMultiplier="1.6"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
