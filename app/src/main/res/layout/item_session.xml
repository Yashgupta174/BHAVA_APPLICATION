<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Session number badge -->
    <FrameLayout
        android:id="@+id/sessionNumContainer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/session_num_bg"
        android:layout_marginEnd="14dp">

        <TextView
            android:id="@+id/tvSessionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_caramel" />

    </FrameLayout>

    <!-- Session info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSessionName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Title"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_espresso"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="3dp" />

        <!-- Meta row: day + category -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSessionDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day 1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_caramel" />

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:background="@drawable/shape_meta_dot"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvSessionCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intro"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_caramel" />

        </LinearLayout>

    </LinearLayout>

    <!-- Right side: play or lock + duration -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="center_vertical">

        <!-- Play button (visible when unlocked) -->
        <FrameLayout
            android:id="@+id/btnPlay"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_play_btn"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:layout_marginStart="2dp"
                android:contentDescription="Play session" />

        </FrameLayout>

        <!-- Lock icon (visible when locked — toggle visibility in adapter) -->
        <ImageView
            android:id="@+id/ivLock"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_lock"
            android:alpha="0.35"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            android:contentDescription="Locked" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 min"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_caramel_light" />

    </LinearLayout>

</LinearLayout>
