<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════╗
    ║   HERO ZONE BREAKDOWN  (440dp total AppBarLayout height) ║
    ╠══════════════════════════════════════════════════════════╣
    ║  14dp  margin + 38dp Back/More btn = 52dp               ║
    ║  ──────────────────────────────────────────────────────  ║
    ║  Zone 1 (0–66dp)       : Nav buttons                    ║
    ║  Zone 2 (66–200dp)     : Empty image space              ║
    ║  Zone 3 (200–210dp)    : 1,247 listening now badge      ║
    ║  Zone 4 (210–290dp)    : Empty image space              ║
    ║  Zone 5 (290–370dp)    : Title + subtitle text          ║
    ║  Zone 6 (370–440dp)    : Options card  (70dp tall)      ║
    ╚══════════════════════════════════════════════════════════╝

    FIX STRATEGY
    ─────────────
    The CollapsingToolbarLayout stacks children like FrameLayout —
    they all share the same coordinate space. Every element is
    therefore positioned using absolute layout_gravity + explicit
    marginTop / marginBottom so no two zones share vertical space.

    Badge   → gravity="top|center_horizontal", marginTop="190dp"
    Title   → gravity="bottom|center_horizontal", paddingBottom="82dp"
                (82dp = 70dp options card + 12dp breathing gap)
    Subtitle→ inside same LinearLayout as title, right above the card

    Options card height ≈ 70dp (12dp label + 20sp text + 28dp padding)
    Title block height  ≈ ~68dp (24sp title ~2 lines + 6dp gap + 14sp sub)
    So title bottom = 82dp from bottom of CollapsingToolbarLayout
    guarantees subtitle is ALWAYS fully visible above the card.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ════════════════════════════════════════════ -->
    <!--         COLLAPSING HERO + APP BAR            -->
    <!-- ════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="460dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!--
            460dp gives us enough room for all zones:
              52dp nav + 140dp image space + 36dp badge + 80dp image space
              + 82dp title+subtitle + 70dp options card = 460dp
        -->
        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bg_parchment"
            app:titleEnabled="false">

            <!-- ── LAYER 1: Full-bleed hero image ── -->
            <ImageView
                android:id="@+id/ivHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hero_session_bg"
                android:scaleType="centerCrop"
                android:contentDescription="Session artwork"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4" />

            <!-- ── LAYER 2: Full bottom scrim (taller = more coverage) ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_bottom_scrim"
                app:layout_collapseMode="parallax" />

            <!-- ── LAYER 3: Listening badge — pinned at marginTop="190dp" ──
                 190dp pushes it well below the nav row (52dp)
                 and well above the title block (starts at ~308dp from top).
                 This puts the badge visually in the upper-centre of the image.
            -->
            <LinearLayout
                android:id="@+id/listeningBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="190dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/listening_badge_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                app:layout_collapseMode="parallax">

                <View
                    android:id="@+id/liveDot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:background="@drawable/live_dot"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/tvListeningCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,247 listening now"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:letterSpacing="0.03" />

            </LinearLayout>

            <!-- ── LAYER 4: Title block ──
                 Anchored to the BOTTOM with paddingBottom="82dp".

                 82dp breakdown:
                   70dp = options card height
                   12dp = breathing gap between card and subtitle

                 The title LinearLayout uses wrap_content height so it
                 expands UPWARD from the 82dp bottom anchor, meaning:
                   - subtitle is always 12dp above the options card top
                   - title is above the subtitle
                   - nothing is clipped by the card
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="bottom|center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="82dp"
                app:layout_collapseMode="parallax">

                <!-- Main title -->
                <TextView
                    android:id="@+id/textLearningTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The Luminous Mysteries of the Holy Rosary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.25"
                    android:shadowColor="#BB000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="10"
                    android:layout_marginBottom="8dp" />

                <!--
                    Subtitle — THIS is the text that was hidden.
                    It is now inside the same LinearLayout as the title,
                    10dp above the bottom anchor (82dp from card top).
                    It will ALWAYS be fully visible.
                -->
                <TextView
                    android:id="@+id/tvSessionSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guided Contemplative Prayer · 27 min"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#F0FFFFFF"
                    android:gravity="center"
                    android:letterSpacing="0.04"
                    android:background="@drawable/subtitle_pill_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />

            </LinearLayout>

            <!-- ── LAYER 5: Options card — pinned to very bottom ──
                 layout_marginBottom="-1dp" removes the gap between
                 the card bottom and the scrollable body.
                 collapseMode="pin" keeps it visible as you scroll.
                 Height ≈ 70dp (measured by its content).
            -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="-1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@color/card_cream"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Guide selector -->
                    <LinearLayout
                        android:id="@+id/selectorGuide"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/selector_left_ripple"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guide"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="3dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvGuideName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fr. Thomas"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso"
                                android:layout_marginEnd="5dp" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_chevron_down"
                                android:contentDescription="Expand guide options" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider_warm" />

                    <!-- Media Options selector -->
                    <LinearLayout
                        android:id="@+id/selectorMedia"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:background="@drawable/selector_right_ripple"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Media Options"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="3dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvMediaDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="27 min"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso"
                                android:layout_marginEnd="5dp" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_chevron_down"
                                android:contentDescription="Expand media options" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── LAYER 6: Back button — pinned top-start ── -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/circle_btn_bg_dark"
                android:padding="10dp"
                android:tint="@color/white"
                android:layout_gravity="top|start"
                android:layout_margin="14dp"
                android:contentDescription="Go back"
                android:stateListAnimator="@null"
                app:layout_collapseMode="pin" />

            <!-- ── LAYER 7: More button — pinned top-end ── -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_more_vert"
                android:background="@drawable/circle_btn_bg_dark"
                android:padding="10dp"
                android:tint="@color/white"
                android:layout_gravity="top|end"
                android:layout_margin="14dp"
                android:contentDescription="More options"
                android:stateListAnimator="@null"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ════════════════════════════════════════════ -->
    <!--             SCROLLABLE BODY                  -->
    <!-- ════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Begin Session button -->
            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="Begin Session"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/white"
                android:background="@drawable/play_btn_bg"
                android:drawableStart="@drawable/ic_play_triangle"
                android:drawablePadding="12dp"
                android:paddingStart="32dp"
                android:gravity="center_vertical"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

            <!-- Pray for an Intention button -->
            <Button
                android:id="@+id/btnPrayIntention"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="4dp"
                android:text="Pray for an Intention"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/accent_color"
                android:background="@drawable/pray_btn_bg"
                android:drawableStart="@drawable/ic_hands_pray"
                android:drawablePadding="12dp"
                android:paddingStart="28dp"
                android:gravity="center_vertical"
                android:stateListAnimator="@null" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Featuring label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEATURING"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_caramel"
                android:letterSpacing="0.12"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp" />

            <!-- Hosts horizontal scroll row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:clipToPadding="false"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:id="@+id/featuringRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Host 1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="20dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/avatar_bg_orange"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/tvHost1Initials"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="FT"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/chip_text_orange" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHost1Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fr. Thomas"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Spiritual Director"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/text_caramel"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Host 2 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="20dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/avatar_bg_green"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/tvHost2Initials"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="SR"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/chip_text_green" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHost2Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sr. Rosa"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contemplative Guide"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/text_caramel"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Host 3 (optional, hidden by default) -->
                    <LinearLayout
                        android:id="@+id/host3Container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/avatar_bg_blue"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/tvHost3Initials"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="DM"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/chip_text_blue" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHost3Name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deacon Mark"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scripture Reader"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/text_caramel"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Journey through the five Luminous Mysteries as guided by Fr. Thomas, accompanied by sacred chant and reflective scripture readings. This contemplative session invites you into deeper union with the mystery of Christ&#8217;s earthly ministry &#8212; from the Baptism in the Jordan to the Institution of the Eucharist."
                android:textSize="14.5sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_caramel"
                android:lineSpacingMultiplier="1.65"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════════ -->
    <!--       MINI PLAYER BAR (pinned bottom)        -->
    <!-- ════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/miniPlayerBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="@color/mini_player_bg">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- Progress track -->
            <View
                android:id="@+id/miniProgressTrack"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/mini_player_progress_track"
                android:layout_alignParentTop="true" />

            <!-- Progress fill -->
            <View
                android:id="@+id/miniProgressFill"
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:background="@color/accent_color"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true" />

            <!-- Thumbnail -->
            <FrameLayout
                android:id="@+id/miniThumbFrame"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/mini_thumb_bg"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:id="@+id/ivMiniThumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_mini_thumb_icon"
                    android:scaleType="center"
                    android:contentDescription="Now playing" />

            </FrameLayout>

            <!-- Mini controls -->
            <LinearLayout
                android:id="@+id/miniControls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageButton
                    android:id="@+id/btnMiniPlay"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_play_triangle"
                    android:background="@drawable/mini_play_btn_bg"
                    android:padding="10dp"
                    android:tint="@color/white"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Play"
                    android:stateListAnimator="@null" />

                <ImageButton
                    android:id="@+id/btnMiniMore"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_more_vert"
                    android:background="@drawable/mini_more_btn_bg"
                    android:padding="6dp"
                    android:tint="@color/mini_player_text_muted"
                    android:contentDescription="More options"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Mini title + subtitle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/miniThumbFrame"
                android:layout_toStartOf="@id/miniControls"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp">

                <TextView
                    android:id="@+id/tvMiniTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The Luminous Mysteries of the Holy Rosary"
