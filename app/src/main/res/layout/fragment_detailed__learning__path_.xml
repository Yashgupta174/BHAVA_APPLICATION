<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ════════════════════════════════════════════ -->
    <!--         COLLAPSING HERO + APP BAR            -->
    <!-- ════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="440dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bg_parchment"
            app:titleEnabled="false">

            <!-- ── Full-bleed hero image ── -->
            <ImageView
                android:id="@+id/ivHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hero_rosary_bg"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4"
                android:contentDescription="Session artwork" />

            <!-- Gradient scrim over bottom of hero -->
            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_bottom_scrim"
                app:layout_collapseMode="parallax" />

            <!-- ── Listening Now badge ── -->
            <LinearLayout
                android:id="@+id/listeningBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/listening_badge_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="80dp"
                app:layout_collapseMode="parallax">

                <!-- Pulsing green dot -->
                <View
                    android:id="@+id/liveDot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:background="@drawable/live_dot"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvListeningCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/listening_now"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- ── Session title + subtitle over hero ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="bottom|center_horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="16dp"
                app:layout_collapseMode="parallax">

                <!-- DYNAMIC TITLE — id = textMorningTitle -->
                <TextView
                    android:id="@+id/textLearningTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/morning_title_placeholder"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvSessionSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/morning_subtitle_placeholder"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#CCFFFFFF"
                    android:gravity="center" />
            </LinearLayout>

            <!-- ── Options selector row (Guide + Media Options) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="-1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/options_card_bg"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Guide selector -->
                    <LinearLayout
                        android:id="@+id/selectorGuide"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/selector_left_ripple">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_guide"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:layout_marginBottom="2dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvGuideName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/guide_name_placeholder"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso"
                                android:layout_marginEnd="6dp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_down"
                                android:tint="@color/text_espresso"
                                android:contentDescription="Expand guide options" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider_warm" />

                    <!-- Media Options selector -->
                    <LinearLayout
                        android:id="@+id/selectorMedia"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/selector_right_ripple">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_media_options"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/text_caramel"
                            android:layout_marginBottom="2dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvMediaDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/media_duration_placeholder"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="serif"
                                android:textColor="@color/text_espresso"
                                android:layout_marginEnd="6dp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_chevron_down"
                                android:tint="@color/text_espresso"
                                android:contentDescription="Expand media options" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Back button pinned top-start ── -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/circle_btn_bg"
                android:padding="10dp"
                android:tint="@color/text_espresso"
                android:layout_gravity="top|start"
                android:layout_margin="14dp"
                android:contentDescription="@string/cd_back"
                app:layout_collapseMode="pin" />

            <!-- ── More options pinned top-end ── -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_more_vert"
                android:background="@drawable/circle_btn_bg"
                android:padding="10dp"
                android:tint="@color/text_espresso"
                android:layout_gravity="top|end"
                android:layout_margin="14dp"
                android:contentDescription="More options"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ════════════════════════════════════════════ -->
    <!--            SCROLLABLE BODY                   -->
    <!-- ════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarThumbVertical="@android:color/transparent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- ── Play Button ── -->
            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_play"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/text_espresso"
                android:background="@drawable/play_btn_bg"
                android:drawableStart="@drawable/ic_play_triangle"
                android:drawablePadding="16dp"
                android:paddingStart="32dp"
                android:gravity="center_vertical"
                app:cornerRadius="50dp" />

            <!-- ── Pray for an Intention Button ── -->
            <Button
                android:id="@+id/btnPrayIntention"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="24dp"
                android:text="@string/btn_pray_intention"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/card_cream"
                android:background="@drawable/pray_btn_bg"
                android:drawableStart="@drawable/ic_hands_pray"
                android:drawablePadding="14dp"
                android:paddingStart="28dp"
                android:gravity="center_vertical"
                app:cornerRadius="50dp" />

            <!-- ── Section divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_warm"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Featuring label ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/featuring_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_brown"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="12dp" />

            <!-- ── Featuring hosts row (horizontally scrollable) ── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:id="@+id/featuringRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Host 1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="20dp">

                        <ImageView
                            android:id="@+id/ivHost1"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:src="@drawable/placeholder_avatar"
                            android:background="@drawable/avatar_bg"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Host 1" />

                        <TextView
                            android:id="@+id/tvHost1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/host1_name_placeholder"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>

                    <!-- Host 2 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginEnd="20dp">

                        <ImageView
                            android:id="@+id/ivHost2"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:src="@drawable/placeholder_avatar"
                            android:background="@drawable/avatar_bg"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Host 2" />

                        <TextView
                            android:id="@+id/tvHost2Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/host2_name_placeholder"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>

                    <!-- Host 3 (optional, shown if data available) -->
                    <LinearLayout
                        android:id="@+id/host3Container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivHost3"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:src="@drawable/placeholder_avatar"
                            android:background="@drawable/avatar_bg"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Host 3" />

                        <TextView
                            android:id="@+id/tvHost3Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="@color/text_espresso" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── Description paragraph ── -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/session_desc_placeholder"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_brown"
                android:lineSpacingMultiplier="1.6"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════════ -->
    <!--       MINI PLAYER BAR (pinned bottom)        -->
    <!-- ════════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/miniPlayerBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/mini_player_bg">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/ivMiniThumb"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/hero_rosary_bg"
                android:background="@drawable/thumbnail_bg"
                android:scaleType="centerCrop"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:contentDescription="Now playing thumbnail" />

            <!-- Mini play + more buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageButton
                    android:id="@+id/btnMiniPlay"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_play_triangle"
                    android:background="@drawable/mini_play_btn_bg"
                    android:padding="10dp"
                    android:tint="@color/card_cream"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Play" />

                <ImageButton
                    android:id="@+id/btnMiniMore"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_more_horiz"
                    android:background="@android:color/transparent"
                    android:tint="@color/card_cream"
                    android:padding="6dp"
                    android:contentDescription="More options" />
            </LinearLayout>

            <!-- Mini title -->
            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/morning_title_placeholder"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:textColor="@color/card_cream"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_toEndOf="@id/ivMiniThumb"

                android:layout_centerVertical="true"
                android:paddingEnd="8dp" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
