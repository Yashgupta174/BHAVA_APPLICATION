<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bhava_background">

    <!-- Wrap ScrollView with SwipeRefreshLayout for Pull-to-Refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutAnimation="@anim/layout_fall_down">

            <!-- ========== HERO HEADER SECTION ========== -->
            <androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="8dp">

                <RelativeLayout
                    android:id="@+id/headerContainer"
                    android:layout_width="match_parent"
                    android:layout_height="450dp"
                    android:background="#280539"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Background Image with Ken Burns effect support -->
                    <ImageView
                        android:id="@+id/headerBackgroundImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Header background"
                        android:src="@drawable/challenge_21days"
                        android:adjustViewBounds="true"/>

                    <!-- Multi-layer Gradient Overlay for better depth -->
                    <!-- Bottom gradient for text readability -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_alignParentBottom="true"
                        android:background="@drawable/gradient_overlay_bottom_strong"/>

                    <!-- Top gradient for status bar area -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_alignParentTop="true"
                        android:background="@drawable/gradient_overlay_top_subtle"/>

                    <!-- Vignette effect for edges -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_vignette"/>

                    <!-- Top Bar with enhanced styling -->
                    <LinearLayout
                        android:id="@+id/topBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"
                        android:gravity="center_vertical"
                        android:elevation="2dp">

                        <!-- Home Title with better typography -->
                        <TextView
                            android:id="@+id/homeTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Home"
                            android:fontFamily="@font/crimson_pro"
                            style="@style/Bhava_TitleText"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:shadowColor="#B0000000"
                            android:shadowDx="0"
                            android:shadowDy="3"
                            android:shadowRadius="8"
                            android:includeFontPadding="false"/>

                        <!-- Enhanced Notification Button -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <com.google.android.material.floatingactionbutton.FloatingActionButton
                                android:id="@+id/notificationIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/notificatio_bell"
                                app:fabSize="mini"
                                app:backgroundTint="#30FFFFFF"
                                app:tint="#FFFFFF"
                                app:elevation="4dp"
                                app:pressedTranslationZ="8dp"
                                app:borderWidth="0dp"
                                android:contentDescription="Notifications"
                                android:stateListAnimator="@null"/>

                            <!-- Notification Badge (optional - hide if no notifications) -->
                            <View
                                android:id="@+id/notificationBadge"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="8dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/notification_badge"
                                android:visibility="gone"/>
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Center Play Button with enhanced design -->


                    <!-- Bottom Content with improved hierarchy -->
                    <LinearLayout
                        android:id="@+id/challengeInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="24dp"
                        android:paddingBottom="32dp"
                        android:elevation="2dp">

                        <!-- Enhanced Current Challenge Badge -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_current_challenge"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp"
                            android:elevation="2dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/icon_fire"
                                app:tint="#FFFFFF"
                                android:contentDescription="Active"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CURRENT CHALLENGE"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.15"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Challenge Title with better readability -->
                        <TextView
                            android:id="@+id/challengeTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="21 Days Dhyan Challenge"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/crimson_pro"
                            android:lineSpacingMultiplier="1.2"
                            android:letterSpacing="0.01"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:shadowColor="#C0000000"
                            android:shadowDx="0"
                            android:shadowDy="2"
                            android:shadowRadius="6"
                            android:layout_marginBottom="12dp"/>

                        <!-- Current Session Info with icon -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/session_info_background"
                            android:paddingStart="12dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="20dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/video_call_logo"
                                app:tint="#FFFFFF"
                                android:contentDescription="Video session"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/sessionInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Day 5 · Guided Dhyan"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:shadowColor="#80000000"
                                android:shadowDx="0"
                                android:shadowDy="1"
                                android:shadowRadius="2"/>
                        </LinearLayout>

                        <!-- Progress Indicator with percentage -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp">

                            <!-- Progress bar -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginBottom="8dp">

                                <!-- Background track -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/progress_track_background"/>

                                <!-- Progress fill -->
                                <View
                                    android:id="@+id/progressFill"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/progress_fill"
                                    android:layout_gravity="start"/>
                            </FrameLayout>

                            <!-- Progress text -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/progressText"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="5 of 21 days completed"
                                    android:textColor="#FFFFFF"
                                    android:textSize="12sp"
                                    android:alpha="0.9"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="0"
                                    android:shadowDy="1"
                                    android:shadowRadius="2"/>

                                <TextView
                                    android:id="@+id/progressPercentage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="24%"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="0"
                                    android:shadowDy="1"
                                    android:shadowRadius="2"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Enhanced Carousel Indicators -->
                        <LinearLayout
                            android:id="@+id/carouselIndicators"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <View
                                android:layout_width="24dp"
                                android:layout_height="4dp"
                                android:layout_margin="3dp"
                                android:background="@drawable/indicator_active"/>

                            <View
                                android:layout_width="8dp"
                                android:layout_height="4dp"
                                android:layout_margin="3dp"
                                android:background="@drawable/indicator_inactive"/>

                            <View
                                android:layout_width="8dp"
                                android:layout_height="4dp"
                                android:layout_margin="3dp"
                                android:background="@drawable/indicator_inactive"/>

                            <View
                                android:layout_width="8dp"
                                android:layout_height="4dp"
                                android:layout_margin="3dp"
                                android:background="@drawable/indicator_inactive"/>

                            <View
                                android:layout_width="8dp"
                                android:layout_height="4dp"
                                android:layout_margin="3dp"
                                android:background="@drawable/indicator_inactive"/>
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========== QUICK ACTIONS SECTION ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/bhava_background">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    style="@style/Bhava_SectionHeader"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Favorites -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:id="@+id/favourite"
                            android:layout_height="64dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/action_button_bg">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/logo_star"
                                android:contentDescription="Favorites"/>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Favorites"
                            style="@style/Bhava_BodyText"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Ask Bhava -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:id="@+id/ask_bhava"
                            android:layout_height="64dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/action_button_bg">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/logo_triangle"
                                android:contentDescription="Ask Bhava"/>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Ask Bhava"
                            style="@style/Bhava_BodyText"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Routine -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:id="@+id/routine"
                            android:layout_height="64dp"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/action_button_bg">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/logo_calendar"
                                android:contentDescription="Routine"/>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Routine"
                            style="@style/Bhava_BodyText"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Recents -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:id="@+id/recent"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/action_button_bg">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/logo_recent"
                                android:contentDescription="Recents"/>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Recents"
                            style="@style/Bhava_BodyText"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ========== DAILY INSPIRATION SECTION ========== -->
            <include layout="@layout/section_daily_inspiration"/>

            <!-- ========== ACTIVE CHALLENGES SECTION ========== -->
            <include layout="@layout/section_active_challenges"/>

<!--            &lt;!&ndash; ========== RECENTLY PRAYED SECTION ========== &ndash;&gt;-->
<!--            <include layout="@layout/section_recently_prayed"/>-->

            <!-- ========== MORNING ROUTINES SECTION ========== -->
            <include layout="@layout/section_morning_routines"/>

<!--            &lt;!&ndash; ========== TRENDING NOW SECTION ========== &ndash;&gt;-->
<!--            <include layout="@layout/section_trending"/>-->

            <!-- ========== DAILY PRACTICES SECTION ========== -->
            <include layout="@layout/section_daily_practices"/>

<!--            &lt;!&ndash; ========== SPIRITUAL MUSIC SECTION ========== &ndash;&gt;-->
<!--            <include layout="@layout/section_spiritual_music"/>-->

            <!-- ========== LEARNING PATHS SECTION ========== -->
            <include layout="@layout/section_learning_paths"/>

            <!-- ========== TIMELESS WISDOM SECTION ========== -->
            <include layout="@layout/section_timeless_wisdom"/>

            <!-- ========== LATEST TEACHINGS SECTION ========== -->
            <include layout="@layout/section_latest_teachings"/>

            <!-- ========== PREMIUM BANNER ========== -->
            <include layout="@layout/section_premium_banner"/>

<!--            &lt;!&ndash; ========== EXPLORE CATEGORIES SECTION ========== &ndash;&gt;-->
<!--            <include layout="@layout/section_explore_categories"/>-->

            <!-- ========== COMMUNITY CAMPAIGNS SECTION ========== -->
            <include layout="@layout/section_community_campaigns"/>

            <!-- ========== PRAYER STATS ========== -->
            <include layout="@layout/section_prayer_stats"/>

            <!-- ========== BOTTOM NAVIGATION SECTION ========== -->
            <include layout="@layout/social_media_layout"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Global Loading ProgressBar (Show when no cache is available) -->
    <ProgressBar
        android:id="@+id/homeProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/action_button_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_featured"
        android:elevation="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_navigation_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:itemIconSize="24dp"
        app:itemTextAppearanceActive="@style/BottomNavTextActive"
        app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
        app:itemRippleColor="@color/bottom_nav_ripple"
        app:itemActiveIndicatorStyle="@style/BottomNavActiveIndicator"
        app:elevation="24dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>