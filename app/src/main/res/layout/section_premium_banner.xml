<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/bhava_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Unlock Your Spiritual Journey"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Access 10,000+ prayers, meditations,\nand exclusive challenges"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAlignment="center"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Free Trial"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/bhava_primary"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp"
            android:paddingStart="48dp"
            android:paddingEnd="48dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
