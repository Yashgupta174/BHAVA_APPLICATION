<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_warm"
    app:cardBackgroundColor="@color/bhava_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Functional Icon Circle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider_warm"
            app:cardBackgroundColor="#FFFFFF">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell_minimal"
                app:tint="@color/bhava_primary"
                android:contentDescription="Notification Icon"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvNotificationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Spiritual Challenge"
                android:textColor="@color/text_espresso"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"/>

            <TextView
                android:id="@+id/tvNotificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join the 21 days Dhyan challenge starting tomorrow."
                android:textColor="@color/text_caramel"
                android:textSize="13sp"
                android:fontFamily="@font/inter"
                android:layout_marginTop="2dp"
                android:lineSpacingExtra="1dp"/>

            <TextView
                android:id="@+id/tvNotificationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 hours ago"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:fontFamily="@font/inter"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btnDeleteNotification"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete_minimal"
            app:tint="@color/text_caramel"
            android:alpha="0.6"
            android:padding="6dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Delete notification"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
