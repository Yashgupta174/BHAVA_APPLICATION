<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivRoutineImg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/gospel_card_bg" />

        <View
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_gravity="bottom"
            android:background="@drawable/card_bottom_fade" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRoutineTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Routine"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/crimson_pro"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvRoutineSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spiritual journey details"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:textColor="#EDD9C0" />
        </LinearLayout>
    </FrameLayout>
</androidx.cardview.widget.CardView>
