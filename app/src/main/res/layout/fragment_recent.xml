<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ══ FIXED HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_parchment"
        android:elevation="6dp">

        <!-- Page Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recents"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_espresso"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="4dp" />

        <!-- Subtitle Row: "12 collections · 8 sessions" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtCollectionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 collections"
                android:textSize="13sp"
                android:textColor="@color/black" />

            <!-- Dot separator -->
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:background="@drawable/shape_dot"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 sessions"
                android:textSize="13sp"
                android:textColor="@color/black" />

        </LinearLayout>

        <!-- Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/bg_parchment"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:tabGravity="start"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@color/text_espresso"
            app:tabTextColor="@color/text_caramel"
            app:tabTextAppearance="@style/FavTabTextAppearance"
            app:tabIndicatorColor="@color/text_espresso"
            app:tabIndicatorHeight="2.5dp"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorGravity="bottom"
            app:tabRippleColor="@color/ripple_brown"
            app:tabPaddingStart="10dp"
            app:tabPaddingEnd="10dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Collections" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_warm" />

    </LinearLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshRecent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentChallenges"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/pbRecentLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRecentEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Your recent activity will appear here."
        android:textColor="@color/text_caramel"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>