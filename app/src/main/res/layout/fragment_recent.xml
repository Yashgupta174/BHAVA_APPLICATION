<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_parchment">

    <!-- ══ FIXED HEADER ══ -->
    <LinearLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_parchment"
        android:elevation="6dp">

        <!-- Page Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recents"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_espresso"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="4dp" />

        <!-- Subtitle Row: "12 collections · 8 sessions" -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtCollectionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 collections"
                android:textSize="13sp"
                android:textColor="@color/black" />

            <!-- Dot separator -->
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:background="@drawable/shape_dot"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 sessions"
                android:textSize="13sp"
                android:textColor="@color/black" />

        </LinearLayout>

        <!-- Tab Layout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/bg_parchment"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:tabGravity="start"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="@color/text_espresso"
            app:tabTextColor="@color/text_caramel"
            app:tabTextAppearance="@style/FavTabTextAppearance"
            app:tabIndicatorColor="@color/text_espresso"
            app:tabIndicatorHeight="2.5dp"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorGravity="bottom"
            app:tabRippleColor="@color/ripple_brown"
            app:tabPaddingStart="10dp"
            app:tabPaddingEnd="10dp">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Collections" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_warm" />

    </LinearLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="158dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── PINNED section label ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PINNED"
                android:textSize="10.5sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="10dp" />

            <!-- ── PINNED CARDS (horizontal scroll) ── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ── PINNED CARD 1: Morning Rituals ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMorningRituals"
                        android:layout_width="165dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="12dp"
                        app:rippleColor="@color/ripple_brown"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Image area -->
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="110dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/learning_path_108_days_of_devotion"
                                    android:contentDescription="Morning Rituals" />

                                <!-- Bottom gradient overlay -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/gradient_overlay_bottom" />

                                <!-- Item count badge -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:layout_margin="10dp"
                                    android:text="24 items"
                                    android:textColor="#FFFFFF"
                                    android:background="@drawable/badge_time"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:elevation="4dp"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="0"
                                    android:shadowDy="2"
                                    android:shadowRadius="4" />

                            </FrameLayout>

                            <!-- Title + subtitle -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:orientation="vertical"
                                android:background="@color/card_content_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Morning Rituals"
                                    android:textColor="@color/text_espresso"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Personal · 24 items"
                                    android:textColor="@color/text_caramel"
                                    android:textSize="11sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:alpha="0.85" />

                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── PINNED CARD 2: Books to Read ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBooksToRead"
                        android:layout_width="165dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="12dp"
                        app:rippleColor="@color/ripple_brown"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="110dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/latest_teaching_divine_grace"
                                    android:contentDescription="Books to Read" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/gradient_overlay_bottom" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:layout_margin="10dp"
                                    android:text="11 items"
                                    android:textColor="#FFFFFF"
                                    android:background="@drawable/badge_time"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:elevation="4dp"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="0"
                                    android:shadowDy="2"
                                    android:shadowRadius="4" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:orientation="vertical"
                                android:background="@color/card_content_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Books to Read"
                                    android:textColor="@color/text_espresso"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Reading · 11 items"
                                    android:textColor="@color/text_caramel"
                                    android:textSize="11sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:alpha="0.85" />

                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ── PINNED CARD 3: Café Spots ── -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCafeSpots"
                        android:layout_width="165dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="12dp"
                        app:rippleColor="@color/ripple_brown"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="110dp">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/latest_teaching_karma_and_dharma"
                                    android:contentDescription="Café Spots" />

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:layout_gravity="bottom"
                                    android:background="@drawable/gradient_overlay_bottom" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:layout_margin="10dp"
                                    android:text="7 items"
                                    android:textColor="#FFFFFF"
                                    android:background="@drawable/badge_time"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:elevation="4dp"
                                    android:shadowColor="#80000000"
                                    android:shadowDx="0"
                                    android:shadowDy="2"
                                    android:shadowRadius="4" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:orientation="vertical"
                                android:background="@color/card_content_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Café Spots"
                                    android:textColor="@color/text_espresso"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Travel · 7 items"
                                    android:textColor="@color/text_caramel"
                                    android:textSize="11sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:alpha="0.85" />

                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── ALL COLLECTIONS section label ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ALL COLLECTIONS"
                android:textSize="10.5sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp" />

            <!-- ── ALL COLLECTIONS: vertical grid of cards ── -->
            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp">

                <!-- Card: Playlist Moods -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPlaylistMoods"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="12dp"
                    app:rippleColor="@color/ripple_brown"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/daily_practices_mantra_chanting"
                                android:contentDescription="Playlist Moods" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/gradient_overlay_bottom" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="10dp"
                                android:text="32 items"
                                android:textColor="#FFFFFF"
                                android:background="@drawable/badge_time"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:elevation="4dp"
                                android:shadowColor="#80000000"
                                android:shadowDx="0"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:orientation="vertical"
                            android:background="@color/card_content_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Playlist Moods"
                                android:textColor="@color/text_espresso"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Music · 32 items"
                                android:textColor="@color/text_caramel"
                                android:textSize="11sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:alpha="0.85" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Quotes & Notes -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuotesNotes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="12dp"
                    app:rippleColor="@color/ripple_brown"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/daily_practices_mantra_chanting"
                                android:contentDescription="Quotes and Notes" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/gradient_overlay_bottom" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="10dp"
                                android:text="18 items"
                                android:textColor="#FFFFFF"
                                android:background="@drawable/badge_time"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:elevation="4dp"
                                android:shadowColor="#80000000"
                                android:shadowDx="0"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:orientation="vertical"
                            android:background="@color/card_content_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Quotes &amp; Notes"
                                android:textColor="@color/text_espresso"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Inspiration · 18 items"
                                android:textColor="@color/text_caramel"
                                android:textSize="11sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:alpha="0.85" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp">

                <!-- Card: Wellness Picks -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWellnessPicks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="12dp"
                    app:rippleColor="@color/ripple_brown"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/daily_practices_daily_pooja"
                                android:contentDescription="Wellness Picks" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/gradient_overlay_bottom" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="10dp"
                                android:text="9 items"
                                android:textColor="#FFFFFF"
                                android:background="@drawable/badge_time"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:elevation="4dp"
                                android:shadowColor="#80000000"
                                android:shadowDx="0"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:orientation="vertical"
                            android:background="@color/card_content_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Wellness Picks"
                                android:textColor="@color/text_espresso"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Health · 9 items"
                                android:textColor="@color/text_caramel"
                                android:textSize="11sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:alpha="0.85" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Design Inspiration -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDesignInspiration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="12dp"
                    app:rippleColor="@color/ripple_brown"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/challeneg_40days_geeta"
                                android:contentDescription="Design Inspiration" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/gradient_overlay_bottom" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="10dp"
                                android:text="15 items"
                                android:textColor="#FFFFFF"
                                android:background="@drawable/badge_time"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:elevation="4dp"
                                android:shadowColor="#80000000"
                                android:shadowDx="0"
                                android:shadowDy="2"
                                android:shadowRadius="4" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:orientation="vertical"
                            android:background="@color/card_content_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Design Inspiration"
                                android:textColor="@color/text_espresso"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Creative · 15 items"
                                android:textColor="@color/text_caramel"
                                android:textSize="11sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:alpha="0.85" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>