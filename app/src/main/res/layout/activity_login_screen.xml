<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Decorative Circle Background Elements - Repositioned -->
    <View
        android:id="@+id/decorCircle1"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/circle_decoration"
        android:alpha="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="-90dp"/>

    <View
        android:id="@+id/decorCircle2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_decoration"
        android:alpha="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="150dp"
        android:layout_marginStart="-60dp"/>

    <!-- Logo Container with Glow Effect - Better Positioned -->
    <androidx.cardview.widget.CardView
        android:id="@+id/logoContainer"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:cardCornerRadius="80dp"
        app:cardElevation="12dp"
        android:layout_marginTop="60dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/illustration"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="16dp"
            android:src="@drawable/logo"/>
    </androidx.cardview.widget.CardView>

    <!-- App Title with Shadow - Clear and Prominent -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bhava"
        android:textColor="#1e2d1e"
        android:textSize="44sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.08"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle with Accent - Clear and Readable -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hope Praylist"
        android:textColor="#3d4e3d"
        android:textSize="16sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-light"
        app:layout_constraintTop_toBottomOf="@id/title"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Divider Line -->
    <View
        android:id="@+id/divider"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="@drawable/gradient_divider"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Enhanced Bottom Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="28dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Welcome Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textAlignment="center"
                android:textSize="22sp"
                android:textColor="#1e2d1e"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose your preferred sign-in method"
                android:textAlignment="center"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp"/>

            <!-- Google Button - Enhanced -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/googleLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue with Google"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textAllCaps="false"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_google"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                android:elevation="2dp"
                app:rippleColor="#20000000"/>

            <!-- Email Button - Enhanced -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/emailLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Continue with Email"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textAllCaps="false"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp"
                app:cornerRadius="28dp"
                app:icon="@drawable/gmail"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@null"
                android:elevation="2dp"
                app:rippleColor="#20000000"/>

            <!-- Apple Button - Enhanced -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/appleLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Continue with Apple"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textAllCaps="false"
                app:backgroundTint="#000000"
                app:cornerRadius="28dp"
                app:icon="@drawable/apple"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="#FFFFFF"
                android:elevation="2dp"
                app:rippleColor="#40FFFFFF"/>

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0"/>
            </LinearLayout>

            <!-- Guest Mode Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/guestLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Continue as Guest"
                android:textColor="#4a5c4a"
                android:textSize="14sp"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.TextButton"
                app:rippleColor="#204a5c4a"/>

            <!-- Terms Text - Enhanced -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By using Bhava you agree to our Terms of Service and Privacy Policy"
                android:textAlignment="center"
                android:textSize="11sp"
                android:textColor="#999999"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>